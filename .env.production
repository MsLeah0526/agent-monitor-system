# 生产环境配置
NODE_ENV=production

# 服务器配置
PORT=3001
WS_PORT=8080
HOST=0.0.0.0

# 数据库配置（MySQL）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=agent_monitor_prod

# JWT密钥（生产环境应使用强密钥）
JWT_SECRET=agent_monitor_prod_secret_key_change_in_production_2024

# 前端配置
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:8080

# 日志配置
LOG_LEVEL=info
LOG_FILE=/var/log/agent-monitor/production.log

# 告警配置
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_SMTP_HOST=
ALERT_EMAIL_SMTP_PORT=587
ALERT_EMAIL_USER=
ALERT_EMAIL_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# 监控配置
HEARTBEAT_INTERVAL=30000
OFFLINE_THRESHOLD=120000
SCORE_ANOMALY_THRESHOLD=20
HIGH_FAILURE_RATE_THRESHOLD=0.1
